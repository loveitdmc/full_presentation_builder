{
  "version": 2,
  "functions": {
    "api/generate.js":       { "maxDuration": 60 },
    "api/generate-text.js":  { "maxDuration": 60 },
    "api/supplier.js":       { "maxDuration": 30 },
    "api/acts.js":           { "maxDuration": 30 },
    "api/acts-list.js":      { "maxDuration": 20 }
  },
  "rewrites": [
    { "source": "/api/generate",       "destination": "/api/generate" },
    { "source": "/api/generate-text",  "destination": "/api/generate-text" },
    { "source": "/api/supplier",       "destination": "/api/supplier" },
    { "source": "/api/acts",           "destination": "/api/acts" },
    { "source": "/api/acts-list",      "destination": "/api/acts-list" },
    { "source": "/(.*)", "destination": "/public/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
